{
  "name": "hearts-mcp-server",
  "version": "1.0.0",
  "description": "Hearts card game MCP server for agent play",
  "author": "wj1918",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wj1918/hearts-mcp-server.git"
  },
  "keywords": ["mcp", "hearts", "card-game", "ai", "agent", "model-context-protocol"],
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-server-hearts": "dist/index.js"
  },
  "files": [
    "dist",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.js.map"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/index.js",
    "dev": "npx tsx src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.7.3",
    "vitest": "^4.1.1"
  }
}
